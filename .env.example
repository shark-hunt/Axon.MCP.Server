# ============================================================================
# Axon MCP Server - Environment Configuration
# ============================================================================
# Copy this file to .env and update with your actual values
# Required fields are marked with (REQUIRED)
# ============================================================================

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
APP_NAME=Axon.MCP.Server
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# ============================================================================
# GITLAB CONFIGURATION
# ============================================================================
GITLAB_URL=https://gitlab.example.org
GITLAB_TOKEN=your_gitlab_token_here                    # (REQUIRED) Personal access token with API access
GITLAB_GROUP_ID=                                       # Optional: Specific group ID to sync
GITLAB_WEBHOOK_SECRET=                                 # Optional: Secret for webhook validation

# ============================================================================
# AZURE DEVOPS CONFIGURATION
# ============================================================================
AZUREDEVOPS_URL=https://devops.example.org/
AZUREDEVOPS_USERNAME=your_username                     # For NTLM: use DOMAIN\username or just username
AZUREDEVOPS_PASSWORD=your_password                     # Password or Personal Access Token (PAT)
AZUREDEVOPS_PROJECT=                                   # Optional: Default project name
AZUREDEVOPS_USE_NTLM=true                             # Enable NTLM authentication
AZUREDEVOPS_SSL_VERIFY=true                           # Keep true by default; set false only for trusted self-signed environments

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL Docker Container Settings (for docker-compose.yml)
# IMPORTANT: These MUST match the credentials in DATABASE_URL
POSTGRES_USER=axon                                     # PostgreSQL username for Docker
POSTGRES_PASSWORD=password                             # PostgreSQL password for Docker
POSTGRES_DB=axon_mcp                                   # PostgreSQL database name for Docker

# Application Database Connection
DATABASE_URL=postgresql://axon:password@localhost:5432/axon_mcp  # (REQUIRED)
# Note: When running via Docker Compose, use: postgresql://axon:password@postgres:5432/axon_mcp
# The hostname changes from 'localhost' to 'postgres' (the Docker service name)

DATABASE_POOL_SIZE=20                                  # Connection pool size
DATABASE_MAX_OVERFLOW=40                               # Max connections beyond pool_size
DATABASE_POOL_TIMEOUT=30                               # Timeout for getting connection (seconds)
DATABASE_ECHO=false                                    # Log all SQL queries (debug only)

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
# Note: Use "redis://redis:6379/0" when running in Docker
#       Use "redis://localhost:6379/0" when running locally
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50                               # Maximum Redis connections
REDIS_CACHE_ENABLED=true                               # Enable/disable Redis caching

# ============================================================================
# CELERY CONFIGURATION (Background Tasks)
# ============================================================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_TIME_LIMIT=3600                           # Hard timeout (seconds)
CELERY_TASK_SOFT_TIME_LIMIT=3000                      # Soft timeout (seconds)

# ============================================================================
# EMBEDDING CONFIGURATION
# ============================================================================
EMBEDDING_PROVIDER=local                               # Options: "local" or "openai"
OPENAI_API_KEY=your_openai_api_key_here               # Required if EMBEDDING_PROVIDER=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSION=1536
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2
EMBEDDING_BATCH_SIZE=100

# ============================================================================
# LLM SUMMARIZATION (for get_module_summary tool)
# ============================================================================
# Provider: "openai", "openrouter", or "ollama"
LLM_PROVIDER=openrouter
# OpenRouter API Key (get free key at https://openrouter.ai/)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Ollama Configuration (if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434/v1

# Model Selection - Free OpenRouter models:
# - google/gemma-3-27b-it:free (default, recommended)
# - meta-llama/llama-3.1-8b-instruct:free
# - qwen/qwen-2.5-72b-instruct:free
# - microsoft/phi-3-mini-128k-instruct:free
# For full list: https://openrouter.ai/models?order=newest&max_price=0
#
# For Ollama, use the model name you pulled (e.g., "llama3", "mistral")
LLM_MODEL=gpt-oss:120b

# Timeout in seconds (default 300 = 5 minutes)
LLM_REQUEST_TIMEOUT=300

# ============================================================================
# VECTOR STORE CONFIGURATION
# ============================================================================
VECTOR_STORE_TYPE=pgvector                            # Vector store backend
VECTOR_SIMILARITY_THRESHOLD=0.7                       # Minimum similarity score (0.0-1.0)

# ============================================================================
# MCP SERVER CONFIGURATION
# ============================================================================
MCP_TRANSPORT=http                                    # Options: "stdio" or "http"
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=8001
MCP_HTTP_PATH=/mcp                                    # HTTP endpoint path

# ============================================================================
# REST API CONFIGURATION
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8080
API_WORKERS=4                                         # Number of worker processes
API_SECRET_KEY=your_secret_key_here_min_32_chars     # (REQUIRED) Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]  # Explicit browser origins (JSON array)
API_RATE_LIMIT=100                                    # Requests per minute per IP

# ============================================================================
# SECURITY & AUTHENTICATION
# ============================================================================
AUTH_ENABLED=true                                     # Enable/disable authentication
ADMIN_API_KEY=                                        # (REQUIRED) Master API key (Service use)
ADMIN_PASSWORD=                                       # (REQUIRED) Admin password for UI login
READ_ONLY_API_KEYS='[]'                               # JSON array of read-only keys (e.g. '["key1"]')
MCP_AUTH_ENABLED=true                                 # Secure default for MCP HTTP; set false only for trusted local clients that cannot send headers
JWT_ALGORITHM=HS256
JWT_SECRET_KEY=your_jwt_secret_here_min_64_chars     # (REQUIRED) Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
LOG_LEVEL=INFO                                        # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json                                       # Options: json, text

# ============================================================================
# REPOSITORY MANAGEMENT
# ============================================================================
REPO_CACHE_DIR=./cache/repos                          # Local cache directory for cloned repos
REPO_MAX_SIZE_MB=1000                                 # Maximum repository size to sync
REPO_CLEANUP_DAYS=7                                   # Days before cleaning old repos

# ============================================================================
# CODE PARSING CONFIGURATION
# ============================================================================
PARSE_TIMEOUT_SECONDS=300                             # Timeout for parsing operations
PARSE_MAX_FILE_SIZE_MB=10                             # Maximum file size to parse

# ============================================================================
# FEATURE EXTRACTION (automated during sync)
# ============================================================================
EXTRACT_API_ENDPOINTS=true                            # Extract API endpoints automatically
EXTRACT_IMPORTS=true                                  # Resolve import relationships
BUILD_CALL_GRAPH=true                                 # Build function call graph (can be slow)
DETECT_PATTERNS=false                                 # Detect design patterns (optional, slow)
EXTRACT_DEPENDENCIES=true                              # Extract package dependencies
EXTRACT_CONFIGURATION=true                             # Extract configuration files

# ============================================================================
# HIERARCHICAL SERVICE DETECTION (for DDD architecture)
# ============================================================================
DETECT_LIBRARY_SERVICES=true                          # Detect class libraries for hierarchical exploration
MIN_LIBRARY_SYMBOLS=10                                # Minimum symbols to detect as library service

# ============================================================================
# MONITORING & OBSERVABILITY
# ============================================================================
METRICS_ENABLED=true                                  # Enable Prometheus metrics
METRICS_PORT=9090                                     # Prometheus metrics port
TRACING_ENABLED=false                                 # Enable OpenTelemetry tracing
TRACING_ENDPOINT=                                     # Optional: OTLP endpoint URL

# ============================================================================
# QUICK SETUP COMMANDS
# ============================================================================
# 1. Generate secure keys:
#    python -c "import secrets; print(f'API_SECRET_KEY={secrets.token_urlsafe(32)}')"
#    python -c "import secrets; print(f'JWT_SECRET_KEY={secrets.token_urlsafe(64)}')"
#
# 2. Get OpenRouter API key (free): https://openrouter.ai/keys
#
# 3. Start services:
#    docker-compose -f docker/docker-compose.yml up -d
#
# 4. Run migrations:
#    alembic upgrade head
# ============================================================================
