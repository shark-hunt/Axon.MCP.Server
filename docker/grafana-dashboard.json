{
  "title": "Axon MCP Server Overview",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {
      "type": "stat",
      "title": "API Requests /s",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "targets": [
        {
          "expr": "sum(rate(api_requests_total[5m]))",
          "legendFormat": "requests/s"
        }
      ]
    },
    {
      "type": "stat",
      "title": "API 5xx /s",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "targets": [
        {
          "expr": "sum(rate(api_requests_total{status=~\"5..\"}[5m]))",
          "legendFormat": "errors/s"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "API Latency (p50/p95/p99)",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum(rate(api_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.95, sum(rate(api_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95"},
        {"expr": "histogram_quantile(0.99, sum(rate(api_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Search Duration (p95)",
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 6},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(search_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "search p95"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Parsing Duration (p95)",
      "gridPos": {"x": 0, "y": 18, "w": 12, "h": 6},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(parsing_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "parsing p95"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "System Resources",
      "gridPos": {"x": 0, "y": 24, "w": 12, "h": 6},
      "targets": [
        {"expr": "cpu_usage_percent", "legendFormat": "CPU %"},
        {"expr": "memory_usage_bytes", "legendFormat": "Memory bytes"}
      ]
    }
  ]
}


